class Solution:
    def numberOfSubmatrices(self, grid):
        m, n = len(grid), len(grid[0])
        
        px = [[0]*(n+1) for _ in range(m+1)]
        py = [[0]*(n+1) for _ in range(m+1)]
        
        for i in range(m):
            for j in range(n):
                px[i+1][j+1] = px[i][j+1] + px[i+1][j] - px[i][j] + (grid[i][j] == 'X')
                py[i+1][j+1] = py[i][j+1] + py[i+1][j] - py[i][j] + (grid[i][j] == 'Y')
        
        res = 0
        
        for i in range(m):
            for j in range(n):
                x = px[i+1][j+1]
                y = py[i+1][j+1]
                
                if x == y and x > 0:
                    res += 1
        
        return res
