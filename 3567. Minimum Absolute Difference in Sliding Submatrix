class Solution:
    def minAbsDiff(self, grid, k):
        m, n = len(grid), len(grid[0])
        res = []

        for i in range(m - k + 1):
            row = []
            for j in range(n - k + 1):
                vals = set()
                for x in range(i, i + k):
                    for y in range(j, j + k):
                        vals.add(grid[x][y])
                vals = sorted(vals)
                if len(vals) <= 1:
                    row.append(0)
                else:
                    min_diff = float('inf')
                    for t in range(1, len(vals)):
                        min_diff = min(min_diff, vals[t] - vals[t-1])
                    row.append(min_diff)
            res.append(row)

        return res
